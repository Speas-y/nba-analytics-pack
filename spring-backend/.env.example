SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/nba_analytics?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
# 与 MySQL 里真实账号一致。常见本机：root + 空密码；若沿用旧 Nest 示例可改为 nba / nba（须先在 MySQL 里创建用户并授权）
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES=15m
REFRESH_DAYS=14
FRONTEND_ORIGIN=http://localhost:5173
DASHBOARD_ORIGINS=http://127.0.0.1:8766,http://localhost:8766
# ---------- 爬虫（与「更新数据」POST /public/nba/data/refresh 同源）----------
# 不设：后端会按「运行时的当前工作目录」自动找 …/爬虫/nba_player_crawler.py（本仓库从 IDEA 跑时 cwd 多为 spring-backend，会命中上一级的 爬虫）。
# 若自动推断失败、或爬虫不在默认位置，在下面写死路径（推荐绝对路径，避免换终端/IDE 后 cwd 不同）：
# NBA_CRAWLER_HOME=/Users/你的用户名/NBA数据分析-pack/爬虫
# 与 spring-backend 同级时也可用相对路径（相对进程 cwd，一般为 spring-backend 目录）：
# NBA_CRAWLER_HOME=../爬虫
# 默认 JSON 在 <爬虫目录>/output；只有 output 不在该目录下时才需要设：
# NBA_CRAWLER_OUTPUT_DIR=/自定义路径/output
# 球队真实分区排名：`output/league_standings_YYYY_YY.json`（爬虫在拉完 BR 球员表后会自动调用 NBA Stats LeagueStandingsV3 写入；也可手动运行 爬虫/fetch_nba_standings.py）。缺少该文件时球队 API 仍可用，但排序退化为「按球员场均均值」。
# 写入战绩后请重新编译并重启 Spring Boot，否则旧进程读不到新路径。自检： spring-backend/scripts/verify-teams-standings.sh 应看到响应头 X-NBA-Standings-Merged: true，且 JSON 含 confRank / wins。
# 不设则优先用 <NBA_CRAWLER_HOME>/.venv/bin/python（建议先在爬虫目录执行 pip install -r requirements.txt）
# NBA_CRAWLER_PYTHON=/Users/你的用户名/NBA数据分析-pack/爬虫/.venv/bin/python
# 仅供公网部署时保护「更新数据」接口；本机可不设
# CRAWLER_REFRESH_TOKEN=
#
# ---------- Render：无法绑信用卡、不能用 Render 自带 Postgres 时（推荐）----------
# 只用 New Web Service + Docker，不配任何外链数据库：
#    SPRING_PROFILES_ACTIVE=h2
#    FRONTEND_ORIGIN=https://nbasjfx.vercel.app
#    JWT_ACCESS_SECRET=<随机长串>
#    CRAWLER_ASYNC=true
#    CRAWLER_REFRESH_TOKEN=<随机串，与 Vercel 的 VITE_REFRESH_TOKEN 一致>
# 说明：h2 为内存库，休眠/重部署后注册用户信息会被清空；/api/public/nba/* 仍正常读镜像内爬虫 JSON。
#
# ---------- Render + 外部免费 Postgres（如 Neon 等，注册常不需信用卡）----------
#    SPRING_PROFILES_ACTIVE=render
#    DATABASE_URL=<对方控制台给的 postgresql://…>
#    其余同 FRONTEND_ORIGIN、JWT_*、CRAWLER_* 等
#
# ---------- Render：有 Render Postgres 且已绑卡时 ----------
#    SPRING_PROFILES_ACTIVE=render + DATABASE_URL 或 RENDER_DB_*（见 RenderDatabaseConfig）
#
# Web Service：Docker；Dockerfile Path = Dockerfile；Root Directory 留空。Health Check：/api/public/nba/seasons
# Vercel：VITE_API_BASE=https://<服务名>.onrender.com/api
